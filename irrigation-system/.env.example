# ─── AWS Credentials ────────────────────────────────────────────────────────
# IAM user must have permissions for:
#   - dynamodb:Scan on IrrigationStatus and IrrigationLogs tables
#   - iot:Publish on topic esp_32/Node_Command
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_IAM_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_IAM_SECRET_ACCESS_KEY

# ─── AWS IoT Core ────────────────────────────────────────────────────────────
# Found under: AWS IoT Core → Settings → Device data endpoint
NEXT_PUBLIC_AWS_IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.ap-south-1.amazonaws.com

# ─── Weather Fallback Coordinates ───────────────────────────────────────────
# Used only if the ESP32 fails to report its geolocation.
# Defaults below are for Bengaluru, India.
WEATHER_LAT=12.9716
WEATHER_LON=77.5946
